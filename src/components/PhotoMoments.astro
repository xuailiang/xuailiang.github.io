---
type SiteData = typeof import("../data/site").site;

interface Props {
  moments: SiteData["photoMoments"];
}

const { moments } = Astro.props;
---

<section class="px-6 py-6 md:px-10 lg:px-14 lg:py-8">
  <div class="flex items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">
    <span class="inline-block h-px w-10 bg-[var(--color-line)]"></span>
    <span>日常片段 / Moments</span>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-12 md:gap-6">
    {moments.map((item, index) => (
      <article
        data-reveal
        class:list={[
          "reveal-up photo-card",
          index === 0 && "md:col-span-5",
          index === 1 && "md:col-span-3 md:translate-y-10",
          index === 2 && "md:col-span-4 md:translate-y-4",
          index === 1 && "delay-1",
          index === 2 && "delay-2",
        ]}
      >
        <div class="photo-card__media">
          <img src={item.src} alt={item.alt} class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="mt-4 flex items-start justify-between gap-4">
          <div>
            <p class="photo-card__label">{item.label}</p>
            <p class="mt-2 max-w-xs text-sm leading-7 text-[var(--color-soft-ink)]">{item.note}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
