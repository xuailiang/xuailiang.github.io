---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"work">;
  index: number;
}

const { project, index } = Astro.props;

const layoutClass =
  index === 0
    ? "md:col-span-7 md:row-span-2"
    : index === 1
      ? "md:col-span-5 md:translate-y-10"
      : "md:col-span-6";

const articleClass = index === 0 ? "work-card work-card--lead" : "work-card work-card--secondary";
---

<article
  data-reveal
  class:list={["reveal-up group", articleClass, layoutClass, index === 1 && "delay-1", index === 2 && "delay-2"]}
  style={`--card-accent: ${project.data.accent ?? "var(--color-accent)"}`}
>
  <a href={`/work/${project.slug}/`} class="block">
    <div class="work-card__media">
      <img
        src={project.data.cover}
        alt={project.data.title}
        class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.03]"
        loading={index === 0 ? "eager" : "lazy"}
      />
    </div>
    <div class="mt-5 grid gap-4 md:grid-cols-[1fr_auto] md:items-start">
      <div>
        <div class="flex flex-wrap items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[var(--color-muted)]">
          {project.data.eyebrow && <span class="story-eyebrow">{project.data.eyebrow}</span>}
          <span>{project.data.year}</span>
          <span class="inline-block h-1 w-1 rounded-full bg-[var(--card-accent)]"></span>
          <span>{project.data.role}</span>
        </div>
        <h3 class="mt-3 font-serif text-4xl leading-none tracking-[-0.03em]">{project.data.title}</h3>
        <p class="mt-4 max-w-xl text-base leading-8 text-[var(--color-soft-ink)]">{project.data.summary}</p>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <p class="story-link">阅读更多</p>
          {project.data.mood && <p class="story-mood">{project.data.mood}</p>}
        </div>
      </div>
      <div class="flex flex-wrap gap-2 md:max-w-[12rem] md:justify-end">
        {project.data.tags.map((tag) => (
          <span class="work-tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>
</article>
