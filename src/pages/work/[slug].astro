---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const work = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);

  return work.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      nextEntry: work[(index + 1) % work.length],
    },
  }));
}

interface Props {
  entry: CollectionEntry<"work">;
  nextEntry: CollectionEntry<"work">;
}

const { entry, nextEntry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.summary} image={entry.data.cover}>
  <main class="px-6 py-8 md:px-10 lg:px-14 lg:py-12">
    <div class="mx-auto max-w-6xl">
      <a
        href="/#stories"
        class="inline-flex items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)] transition duration-300 hover:text-[var(--color-accent)]"
      >
        <span class="inline-block h-px w-10 bg-[var(--color-line)]"></span>
        返回精选片段
      </a>

      <header class="mt-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_16rem] lg:items-end">
        <div data-reveal class="reveal-up">
          <div class="flex flex-wrap gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-[var(--color-muted)]">
            <span>{entry.data.year}</span>
            <span class="inline-block h-1 w-1 rounded-full bg-[var(--color-accent)]"></span>
            <span>{entry.data.role}</span>
          </div>
          <h1 class="mt-5 max-w-4xl font-serif text-6xl leading-[0.92] tracking-[-0.05em] md:text-7xl">
            {entry.data.title}
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-9 text-[var(--color-soft-ink)]">
            {entry.data.summary}
          </p>
          {entry.data.link && (
            <a
              href={entry.data.link}
              target="_blank"
              rel="noreferrer"
              class="story-link mt-8 inline-flex"
            >
              查看链接
            </a>
          )}
        </div>
        <div data-reveal class="reveal-up delay-1 flex flex-wrap gap-2 lg:justify-end">
          {entry.data.tags.map((tag) => (
            <span class="work-tag">{tag}</span>
          ))}
        </div>
      </header>

      <figure data-reveal class="reveal-up delay-2 mt-12 overflow-hidden rounded-[2.2rem] border border-[var(--color-line-strong)] bg-black/5">
        <img src={entry.data.cover} alt={entry.data.title} class="h-full w-full object-cover" />
      </figure>

      <article class="case-body mx-auto mt-16 max-w-3xl">
        <Content />
      </article>

      <section class="mt-[4.5rem] border-t border-[var(--color-line)] pt-8">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">下一则片段</p>
        <a href={`/work/${nextEntry.slug}/`} class="group mt-4 block max-w-2xl">
          <h2 class="font-serif text-5xl leading-none tracking-[-0.04em] transition duration-300 group-hover:text-[var(--color-accent)]">
            {nextEntry.data.title}
          </h2>
          <p class="mt-4 text-base leading-8 text-[var(--color-soft-ink)]">{nextEntry.data.summary}</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
